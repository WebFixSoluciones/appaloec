rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: verifica si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: verifica si el usuario tiene rol de administrador
    function isAdmin() {
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Archivos de perfil de usuario (avatars)
    match /users/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Catálogo de imágenes de jugos verdes (solo admins escriben, usuarios leen)
    match /juices/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /recipes/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Catálogo de imágenes de planes (solo admins escriben, usuarios leen)
    match /diet_plans/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /protocols/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Catálogo de cursos (miniatuas, portadas)
    match /courses/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Videos de lecciones del curso
    match /lessons_videos/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Banners promocionales y de marketing
    match /marketing_banners/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
