rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: verifica si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: verifica si el usuario accede a sus propios datos
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: verifica si el usuario tiene rol de administrador
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Regla para la colección 'users'
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Permitir registro inicial
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Regla para la colección 'imc_records'
    match /imc_records/{recordId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userUid == request.auth.uid || request.resource.data.userUid == request.auth.uid || isAdmin());
    }

    // Regla para la colección 'juices' (recetas)
    match /juices/{juiceId} {
      allow read: if isAuthenticated(); // Todos los usuarios registrados pueden ver las recetas
      allow write: if isAdmin(); // Solo administradores pueden agregar/editar recetas
    }

    // Regla para la colección 'diet_plans'
    match /diet_plans/{planId} {
      allow read: if isAuthenticated(); // Todos los usuarios registrados pueden ver los planes
      allow write: if isAdmin(); // Solo administradores pueden gestionar los planes
    }

    // Regla para la colección 'user_schedules'
    match /user_schedules/{scheduleId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userUid == request.auth.uid || request.resource.data.userUid == request.auth.uid || isAdmin());
    }

    // Regla para la colección 'videocourses' / 'courses'
    match /videocourses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Regla para la colección 'lessons'
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Regla para la colección 'memberships'
    match /memberships/{membershipId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Regla para la colección 'gateways' (CRÍTICO: Solo admin lee y escribe)
    match /gateways/{gatewayId} {
      allow read, write: if isAdmin();
    }

    // Regla para la colección 'orders' (facturas y compras)
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Regla para la colección 'marketing_banners'
    match /marketing_banners/{bannerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Regla para la colección 'user_progress'
    match /user_progress/{progressId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Regla para la colección 'audit_logs' (Bitácora inmutable)
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Permitir loggear acciones desde el cliente
      allow update, delete: if false; // Nadie puede editar o borrar logs de auditoría
    }

    // Regla para la colección 'system_settings'
    match /system_settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Soporte a Módulos Futuros y Gamificación ---
    
    // Streaks de hábitos
    match /gamification_streaks/{streakId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Logros desbloqueados
    match /user_achievements/{achievementId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Diario de consumo de jugos
    match /juicing_journal/{journalId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Preferencias y objetivos de salud
    match /personalized_goals/{goalId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Lista de compras
    match /grocery_lists/{listId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
